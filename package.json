{
  "name": "claude-nvidia-proxy",
  "version": "1.1.0",
  "description": "A proxy server that converts Anthropic API requests to NVIDIA API format",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cnp": "./dist/cli/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "node script/build.js",
    "release": "standard-version",
    "start": "node dist/cli/index.js start",
    "dev": "node src/cli/index.js start",
    "serve": "node src/cli/index.js start",
    "test": "echo \"No tests yet\" && exit 0",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "anthropic",
    "nvidia",
    "proxy",
    "api",
    "claude",
    "llama",
    "ai"
  ],
  "author": "hexoh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hexoh/claude-nvidia-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/hexoh/claude-nvidia-proxy/issues"
  },
  "homepage": "https://github.com/hexoh/claude-nvidia-proxy#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "config",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "standard-version": "^9.5.0"
  }
}
